<div class="py-8" data-controller="queue-updater" data-queue-updater-store-id-value="<%= @store.id %>">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">📋 Fila de Atendimento</h1>
    <p class="text-gray-600 mt-2"><%= @store.name %></p>
  </div>

  <div id="queue-widget" data-store-id="<%= @store.id %>">
    <%= render 'shared/queue_widget', store: @store %>
  </div>

  <div class="mt-8 p-4 bg-blue-50 rounded-lg border border-blue-200">
    <p class="text-sm text-blue-600">
      💡 A fila atualiza automaticamente. Não é necessário atualizar a página.
    </p>
  </div>
</div>
