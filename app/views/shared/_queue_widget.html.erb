<div id="queue-widget" data-store-id="<%= store.id %>">
  <% queue_statuses = SellerQueueStatus.where(store: store).includes(:seller).order(:position) %>
  <% attending = queue_statuses.find { |qs| qs.status == "attending" } %>
  <% current_user_status = queue_statuses.find { |qs| qs.seller == current_user } if user_signed_in? %>
  <% upcoming_sellers = queue_statuses.select { |qs| qs.status == "idle" }.first(5) %>

  <!-- Currently Attending Section -->
  <% if attending %>
    <div class="bg-blue-50 p-4 rounded-lg border border-blue-200 mb-4">
      <p class="text-sm text-blue-600 font-medium">👤 Sendo Atendido Agora</p>
      <p class="text-lg font-semibold text-gray-900"><%= attending.seller.name %></p>
    </div>
  <% end %>

  <!-- User's Position Section -->
  <% if user_signed_in? %>
    <% if current_user_status %>
      <div class="bg-indigo-50 border-l-4 border-indigo-400 p-6 mb-8 rounded">
        <h2 class="text-xl font-bold text-indigo-900 mb-4">📍 Sua Posição</h2>
        <div class="text-5xl font-bold text-indigo-600 mb-2"><%= current_user_status.position %></div>
        <% if current_user_status.status == "idle" && !attending %>
          <!-- Only show start button if user is next and no one is attending -->
          <% if current_user_status.position == 1 %>
            <%= form_with(url: store_attendances_path(store), method: :post, local: true) do |form| %>
              <%= form.submit "📱 Iniciar Atendimento", class: "w-full px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 font-medium" %>
            <% end %>
          <% end %>
        <% end %>
        <%= link_to "← Sair da Fila", store_queue_leave_path(store), method: :delete, class: "block mt-2 text-center px-4 py-2 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 font-medium" %>
      </div>
    <% else %>
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 mb-8 rounded">
        <h2 class="text-xl font-bold text-yellow-900 mb-4">➕ Entrar na Fila</h2>
        <%= button_to "Entrar na Fila", store_queue_join_path(store), method: :post, class: "w-full px-4 py-2 bg-yellow-600 text-white rounded-lg hover:bg-yellow-700 font-medium" %>
      </div>
    <% end %>
  <% end %>

  <!-- Upcoming Sellers Section -->
  <div class="bg-white rounded-lg shadow mt-6">
    <h2 class="text-2xl font-bold text-gray-900 p-6 border-b">📋 Próximos na Fila</h2>
    <div class="p-6">
      <% if upcoming_sellers.any? %>
        <% upcoming_sellers.each_with_index do |queue_status, index| %>
          <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg border border-gray-200 mb-3">
            <span class="inline-block w-10 h-10 bg-indigo-600 text-white rounded-full flex items-center justify-center font-bold text-lg">
              <%= index + 1 %>
            </span>
            <div>
              <p class="text-lg font-semibold text-gray-900"><%= queue_status.seller.name %></p>
              <p class="text-sm text-gray-500">Posição: <%= queue_status.position %></p>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-center text-gray-600 py-4">Nenhum vendedor esperando</p>
      <% end %>
    </div>
  </div>
</div>
