<div class="py-8">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900"><%= @store.name %> - Dashboard</h1>
    <p class="text-gray-600 mt-2">Indicadores de desempenho e gestão de atendimentos</p>
  </div>

  <!-- KPI Cards Section -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <!-- Conversion Rate Card -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-600 text-sm font-medium">Taxa de Conversão</p>
          <p class="text-3xl font-bold text-indigo-600"><%= number_to_percentage(@conversion_rate, precision: 1) %></p>
          <p class="text-gray-500 text-xs mt-1">Hoje</p>
        </div>
        <div class="text-4xl">📊</div>
      </div>
    </div>

    <!-- Total Attendances Card -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-600 text-sm font-medium">Total de Atendimentos</p>
          <p class="text-3xl font-bold text-blue-600"><%= @total_attendances %></p>
          <p class="text-gray-500 text-xs mt-1">Hoje</p>
        </div>
        <div class="text-4xl">📞</div>
      </div>
    </div>

    <!-- Total Sales Card -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-600 text-sm font-medium">Vendas Confirmadas</p>
          <p class="text-3xl font-bold text-green-600"><%= @sales %></p>
          <p class="text-gray-500 text-xs mt-1">Hoje</p>
        </div>
        <div class="text-4xl">✅</div>
      </div>
    </div>

    <!-- Average Attendance Time Card -->
    <div class="bg-white rounded-lg shadow p-6">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-gray-600 text-sm font-medium">Tempo Médio</p>
          <p class="text-3xl font-bold text-orange-600"><%= number_with_precision(@average_attendance_time, precision: 1) %>m</p>
          <p class="text-gray-500 text-xs mt-1">Por atendimento</p>
        </div>
        <div class="text-4xl">⏱️</div>
      </div>
    </div>
  </div>

  <!-- Queue Status Section -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Fila Atual</h2>
      <% current_attending = SellerQueueStatus.where(store: @store, status: "attending").includes(:seller).first %>
      <% idle_sellers = SellerQueueStatus.where(store: @store, status: "idle").includes(:seller).order(:position).limit(5) %>

      <% if current_attending %>
        <div class="mb-4 p-3 bg-blue-50 rounded-lg border border-blue-200">
          <p class="text-sm text-blue-600 font-medium">Sendo Atendido</p>
          <p class="font-semibold text-gray-900"><%= current_attending.seller.name %></p>
        </div>
      <% else %>
        <div class="mb-4 p-3 bg-gray-50 rounded-lg border border-gray-200">
          <p class="text-sm text-gray-600 font-medium">Ninguém sendo atendido</p>
        </div>
      <% end %>

      <div>
        <p class="text-sm text-gray-600 font-medium mb-2">Próximos (< 5)</p>
        <% if idle_sellers.any? %>
          <ul class="space-y-2">
            <% idle_sellers.each_with_index do |qs, index| %>
              <li class="flex items-center gap-2 text-sm">
                <span class="inline-block w-6 h-6 bg-indigo-600 text-white rounded-full flex items-center justify-center text-xs font-bold"><%= index + 1 %></span>
                <span><%= qs.seller.name %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-sm text-gray-500">Nenhum vendedor esperando</p>
        <% end %>
      </div>
    </div>

    <!-- Performance Insights -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Insights</h2>

      <% no_sales = @total_attendances - @sales %>
      <% pending_count = @store.attendances.where(result: "pending").count %>

      <div class="space-y-3">
        <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
          <p class="text-sm font-medium text-gray-900">Vendas</p>
          <p class="text-lg font-bold text-green-600"><%= @sales %></p>
        </div>
        <div class="flex items-center justify-between p-3 bg-red-50 rounded-lg">
          <p class="text-sm font-medium text-gray-900">Sem venda</p>
          <p class="text-lg font-bold text-red-600"><%= no_sales %></p>
        </div>
        <% if pending_count > 0 %>
          <div class="flex items-center justify-between p-3 bg-yellow-50 rounded-lg">
            <p class="text-sm font-medium text-gray-900">Pendentes</p>
            <p class="text-lg font-bold text-yellow-600"><%= pending_count %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Actions -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Ações</h2>
      <div class="space-y-2">
        <%= link_to "← Voltar para Loja", store_path(@store), class: "block w-full text-center px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 font-medium" %>
        <%= link_to "Ir para Fila", store_queue_path(@store), class: "block w-full text-center px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium" %>
        <%= link_to "Minhas Lojas", stores_path, class: "block w-full text-center px-4 py-2 bg-indigo-100 text-indigo-700 rounded-lg hover:bg-indigo-200 font-medium" %>
      </div>
    </div>
  </div>

  <!-- Today's Attendance Table -->
  <div class="bg-white rounded-lg shadow">
    <div class="border-b p-6">
      <h2 class="text-2xl font-bold text-gray-900">Atendimentos de Hoje</h2>
    </div>
    <div class="overflow-x-auto">
      <% attendances_today = @store.attendances.today(@store).includes(:seller).order(started_at: :desc) %>
      <% if attendances_today.any? %>
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50 border-b">
              <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Vendedor</th>
              <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Resultado</th>
              <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Duração</th>
              <th class="px-6 py-3 text-left text-sm font-semibold text-gray-900">Início</th>
            </tr>
          </thead>
          <tbody>
            <% attendances_today.each do |attendance| %>
              <tr class="border-b hover:bg-gray-50">
                <td class="px-6 py-3 text-sm text-gray-900"><%= attendance.seller.name %></td>
                <td class="px-6 py-3 text-sm">
                  <% case attendance.result %>
                    <% when "sale" %>
                      <span class="inline-block bg-green-100 text-green-800 px-3 py-1 rounded-full text-xs font-semibold">✅ Vendeu</span>
                    <% when "no_sale" %>
                      <span class="inline-block bg-red-100 text-red-800 px-3 py-1 rounded-full text-xs font-semibold">❌ Não Vendeu</span>
                    <% when "pending" %>
                      <span class="inline-block bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-xs font-semibold">⏳ Pendente</span>
                    <% else %>
                      <span class="inline-block bg-gray-100 text-gray-800 px-3 py-1 rounded-full text-xs font-semibold">-</span>
                    <% end %>
                </td>
                <td class="px-6 py-3 text-sm text-gray-600"><%= attendance.duration_minutes ? "#{attendance.duration_minutes}m" : "—" %></td>
                <td class="px-6 py-3 text-sm text-gray-600"><%= attendance.started_at.strftime("%H:%M:%S") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="p-6 text-center">
          <p class="text-gray-600">Nenhum atendimento registrado hoje</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
