<div class="py-8">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @store.name %></h1>
      <p class="text-gray-600 mt-2">
        <span class="inline-block bg-gray-100 px-3 py-1 rounded-full text-sm mr-2"><%= @store.cnpj %></span>
        <span class="inline-block bg-gray-100 px-3 py-1 rounded-full text-sm mr-2"><%= @store.timezone %></span>
        <span class="inline-block bg-gray-100 px-3 py-1 rounded-full text-sm">📱 <%= @store.phone %></span>
      </p>
    </div>
    <div>
      <%= link_to "Editar Loja", edit_store_path(@store), class: "px-4 py-2 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 font-medium" %>
    </div>
  </div>

  <!-- Fila Digital Section -->
  <div class="bg-white rounded-lg shadow mb-8">
    <div class="border-b p-6 flex items-center justify-between">
      <h2 class="text-2xl font-bold text-gray-900">📋 Fila Digital</h2>
      <%= link_to "Ver Fila Completa →", queue_path, class: "px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium" %>
    </div>
    <div class="p-6">
      <% attending = SellerQueueStatus.where(store: @store, status: "attending").includes(:seller).first %>
      <% queue_count = SellerQueueStatus.where(store: @store, status: "idle").count %>

      <% if attending %>
        <div class="bg-blue-50 p-4 rounded-lg border border-blue-200 mb-4">
          <p class="text-sm text-blue-600 font-medium">👤 Sendo Atendido Agora</p>
          <p class="text-lg font-semibold text-gray-900"><%= attending.seller.name %></p>

          <% current_attendance = @store.attendances.where(seller: attending.seller).where(ended_at: nil).first %>
          <% if current_attendance && current_attendance.seller == current_user %>
            <div class="mt-4 flex gap-3">
              <%= button_to "✅ Vendeu", finish_attendance_path(current_attendance, result: "sale"), method: :patch, class: "flex-1 px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 font-medium" %>
              <%= button_to "❌ Não Vendeu", finish_attendance_path(current_attendance, result: "no_sale"), method: :patch, class: "flex-1 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 font-medium" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="text-center">
        <p class="text-gray-600">
          <span class="text-3xl font-bold text-indigo-600"><%= queue_count %></span>
          <span class="block text-sm mt-1">vendedores na fila</span>
        </p>
      </div>
    </div>
  </div>

  <!-- Actions Section -->
  <div class="bg-white rounded-lg shadow">
    <div class="border-b p-6">
      <h2 class="text-2xl font-bold text-gray-900">⚙️ Ações</h2>
    </div>
    <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= link_to "Visualizar Dashboard", dashboard_store_path(@store), class: "px-4 py-3 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium text-center" %>
      <%= link_to "Gerenciar Vendedores", "#", class: "px-4 py-3 bg-indigo-100 text-indigo-700 rounded-lg hover:bg-indigo-200 font-medium text-center" %>
      <%= link_to "Voltar para Lojas", stores_path, class: "px-4 py-3 bg-gray-200 text-gray-700 rounded-lg hover:bg-gray-300 font-medium text-center md:col-span-2" %>
    </div>
  </div>
</div>
